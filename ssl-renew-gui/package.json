    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.3",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@vitejs/plugin-react": "4.2.1",
    "typescript": "5.4.5",
    "vite": "4.5.3"
  }
}
