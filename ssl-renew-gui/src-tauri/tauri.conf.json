{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSL证书自动续期",
  "version": "0.1.0",
  "identifier": "com.local.ssl-renew",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSL证书自动续期",
        "width": 1120,
        "height": 760,
        "minWidth": 1000,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
